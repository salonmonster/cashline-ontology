<div id="<%= dom_id(run, :panel) %>" class="space-y-6">
  <div class="rounded border border-slate-200 bg-white p-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-semibold">Run <span class="font-mono text-base text-slate-700"><%= run.directory_token %></span></h1>
        <p class="text-sm text-slate-600">API <%= run.api_version %> · seed: <code><%= run.seed_objects.to_a.join(", ") %></code></p>
      </div>
      <div class="flex items-center gap-3">
        <%= status_badge(run.status) %>
        <% if run.include_sensitive %><span class="rounded bg-amber-100 text-amber-900 px-1.5 py-0.5 text-[10px] uppercase tracking-wide">sensitive</span><% end %>
      </div>
    </div>

    <dl class="mt-4 grid grid-cols-2 gap-y-2 gap-x-6 text-sm">
      <dt class="text-slate-500">Started</dt><dd><%= time_ago_or_dash(run.started_at) %></dd>
      <dt class="text-slate-500">Completed</dt><dd><%= time_ago_or_dash(run.completed_at) %></dd>
      <dt class="text-slate-500">Objects extracted</dt><dd><%= run.sobjects.count %></dd>
      <dt class="text-slate-500">Triggered by</dt><dd><%= run.user&.email_address || "—" %></dd>
      <% if run.include_sensitive && run.retained_until %>
        <dt class="text-slate-500">Retained until</dt><dd><%= run.retained_until.to_date %></dd>
      <% end %>
    </dl>

    <%= render "profile_progress", run: run %>

    <% if run.error_message.present? %>
      <div class="mt-4 rounded bg-rose-50 text-rose-900 p-3 text-sm whitespace-pre-wrap"><%= run.error_message %></div>
    <% end %>

    <% if run.partial_failures.any? %>
      <div class="mt-4 rounded bg-amber-50 text-amber-900 p-3 text-sm">
        <p class="font-medium mb-1">Partial failures (<%= run.partial_failures.size %>):</p>
        <ul class="list-disc pl-5 space-y-0.5">
          <% run.partial_failures.each do |pf| %>
            <li><code><%= pf["object_api_name"] %></code> — <%= pf["reason"] %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <% if run.complete? || run.complete_with_warnings? %>
    <div class="rounded border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-semibold mb-3">Next steps</h2>
      <ul class="space-y-2 text-sm">
        <li><%= link_to "View extraction results (objects)", objects_path(run: run.id), class: "text-blue-700 underline" %></li>
        <% if respond_to?(:erds_path) %><li><%= link_to "Per-domain ERDs", erds_path(run: run.id), class: "text-blue-700 underline" %></li><% end %>
        <% if respond_to?(:visualizations_path) %><li><%= link_to "Visualizations (graph, bubble chart, heatmap)", visualizations_path(run: run.id), class: "text-blue-700 underline" %></li><% end %>
        <% if respond_to?(:reports_hub_orphan_path) %><li><%= link_to "Hub / orphan report", reports_hub_orphan_path(run: run.id), class: "text-blue-700 underline" %></li><% end %>
      </ul>
    </div>
  <% end %>
</div>

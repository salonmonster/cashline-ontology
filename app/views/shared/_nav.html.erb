<% if authenticated? %>
  <%# Active-section detection — match by controller name so subroutes
      (e.g. /runs/:id, /objects/:api_name, the mapping value/proposal
      controllers) still highlight the section. %>
  <% current_section = controller_name %>
  <% nav_items = [
       ["Runs",      :runs_path,               %w[runs]],
       ["Objects",   :objects_path,            %w[objects]],
       ["Mappings",  :mappings_path,           %w[mappings mapping_value_entries mapping_proposals]],
       ["ERDs",      :erds_path,               %w[erds]],
       ["Visualize", :visualizations_path,     %w[visualizations]],
       ["Reports",   :reports_hub_orphan_path, %w[reports]],
       ["Diff",      :new_diff_path,           %w[diffs]]
     ] %>

  <aside class="sticky top-0 h-screen w-56 shrink-0 overflow-y-auto bg-white border-r border-slate-200 flex flex-col">
    <div class="px-4 py-4 border-b border-slate-200">
      <%= link_to root_path, class: "flex items-center gap-2", title: "CashLine ontology" do %>
        <%= render "shared/logo", size_class: "h-8 w-auto" %>
      <% end %>
    </div>

    <nav class="flex-1 px-2 py-3 space-y-0.5">
      <% nav_items.each do |label, path_helper, sections| %>
        <% next unless respond_to?(path_helper) %>
        <% active = sections.include?(current_section) %>
        <%= link_to label, send(path_helper),
              class: "block rounded px-3 py-2 text-sm font-medium #{active ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
      <% end %>
    </nav>

    <div class="border-t border-slate-200 px-4 py-3 text-xs space-y-2">
      <% if current_run %>
        <div class="rounded bg-slate-100 px-2 py-2" title="Active run — click to open">
          <div class="flex items-center gap-1.5 text-slate-500 mb-1">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Active run
          </div>
          <%= link_to current_run.directory_token, run_path(current_run), class: "font-mono text-slate-900 underline decoration-dotted break-all" %>
          <div class="text-slate-500 mt-1"><%= current_run.sobjects.count %> objects</div>
          <% if current_run.include_sensitive %>
            <span class="badge-warning mt-1 inline-block">sensitive</span>
          <% end %>
        </div>
      <% end %>
      <div class="text-slate-500 break-all"><%= Current.user&.email_address %></div>
      <%= button_to "Sign out", session_path, method: :delete, class: "btn-ghost btn-sm" %>
    </div>
  </aside>
<% end %>

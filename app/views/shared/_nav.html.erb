<% if authenticated? %>
  <nav class="bg-white border-b border-slate-200 mb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
      <div class="flex items-center gap-6">
        <%= link_to "Cashline", root_path, class: "font-semibold text-slate-900" %>
        <% nav_items = [
             ["Runs", :runs_path],
             ["Objects", :objects_path],
             ["ERDs", :erds_path],
             ["Graph", :graph_path],
             ["Reports", :reports_hub_orphan_path]
           ] %>
        <% nav_items.each do |label, path_helper| %>
          <% next unless respond_to?(path_helper) %>
          <%= link_to label, send(path_helper), class: "text-sm text-slate-700 hover:text-slate-900" %>
        <% end %>
      </div>
      <div class="flex items-center gap-4">
        <% if current_run %>
          <span class="inline-flex items-center gap-2 rounded bg-slate-100 px-3 py-1 text-xs text-slate-700" title="Active run">
            <span>Active run:</span>
            <%= link_to current_run.directory_token, run_path(current_run), class: "font-mono underline decoration-dotted" %>
            <span class="text-slate-500"><%= time_ago_or_dash(current_run.completed_at || current_run.started_at) %> · <%= current_run.sobjects.count %> objects</span>
            <% if current_run.include_sensitive %>
              <span title="Sensitive run" class="rounded bg-amber-100 text-amber-900 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide">sensitive</span>
            <% end %>
          </span>
        <% end %>
        <span class="text-sm text-slate-600"><%= Current.user&.email_address %></span>
        <%= button_to "Sign out", session_path, method: :delete, class: "text-sm text-slate-700 hover:text-slate-900 underline" %>
      </div>
    </div>
  </nav>
<% end %>

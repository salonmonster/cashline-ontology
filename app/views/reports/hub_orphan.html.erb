<% content_for(:title, "Hub / orphan report") %>
<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-semibold">Hub / orphan report</h1>
    <p class="text-sm text-slate-600">Objects ranked by total relationship degree. Orphans listed separately.</p>
  </div>
  <% if @run %><%= link_to "Download CSV", reports_hub_orphan_path(run: @run.id, format: :csv), class: "rounded bg-slate-200 px-3 py-2 text-sm" %><% end %>
</div>

<% if @run.nil? %>
  <p class="text-slate-700">No active run. <%= link_to "Pick one", runs_path, class: "text-blue-700 underline" %>.</p>
<% else %>
  <section class="rounded border border-slate-200 bg-white p-4 mb-6">
    <h2 class="text-lg font-semibold mb-2">Most connected (hubs)</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
          <tr><th class="px-3 py-2">Object</th><th class="px-3 py-2">Namespace</th><th class="px-3 py-2">Outbound</th><th class="px-3 py-2">Inbound</th><th class="px-3 py-2">Total</th></tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @nonorphans.first(50).each do |r| %>
            <tr>
              <td class="px-3 py-2"><%= link_to r[:api_name], object_path(r[:api_name], run: @run.id), class: "font-mono text-blue-700 underline" %></td>
              <td class="px-3 py-2 text-slate-700"><%= r[:namespace_prefix].presence || "standard" %></td>
              <td class="px-3 py-2"><%= r[:out_count] %></td>
              <td class="px-3 py-2"><%= r[:in_count] %></td>
              <td class="px-3 py-2 font-medium"><%= r[:out_count].to_i + r[:in_count].to_i %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="rounded border border-slate-200 bg-white p-4">
    <h2 class="text-lg font-semibold mb-2">Orphans (no inbound or outbound)</h2>
    <% if @orphans.empty? %>
      <p class="text-slate-600 text-sm">None.</p>
    <% else %>
      <ul class="space-y-1 text-sm">
        <% @orphans.each do |r| %>
          <li><%= link_to r[:api_name], object_path(r[:api_name], run: @run.id), class: "font-mono text-blue-700 underline" %><span class="text-slate-500"> · <%= r[:namespace_prefix].presence || "standard" %></span></li>
        <% end %>
      </ul>
    <% end %>
  </section>
<% end %>

<% content_for(:title, "Schema graph") %>
<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-semibold">Schema graph</h1>
    <p class="text-sm text-slate-600">Force-directed view of all in-scope objects and relationships.</p>
  </div>
</div>

<% if @run.nil? %>
  <div class="rounded border border-dashed border-slate-300 p-10 text-center bg-white">
    <p class="text-slate-700">No active run. <%= link_to "Pick one", runs_path, class: "text-blue-700 underline" %>.</p>
  </div>
<% else %>
  <div class="rounded border border-slate-200 bg-white p-4"
       data-controller="graph"
       data-graph-endpoint-value="<%= data_graph_path(run: @run.id) %>"
       data-graph-object-path-value="<%= object_path('__API_NAME__', run: @run.id) %>">
    <div class="flex items-center gap-3 mb-3 text-sm">
      <label>Namespace:
        <select data-graph-target="namespaceFilter" class="rounded border-slate-300 text-sm">
          <option value="">All</option>
        </select>
      </label>
      <label>Min records:
        <input type="number" min="0" value="0" data-graph-target="minRecords" class="w-24 rounded border-slate-300 text-sm">
      </label>
      <button data-action="graph#applyFilters" class="rounded bg-slate-200 px-2 py-1 text-xs">Apply</button>
      <button data-action="graph#fit" class="rounded bg-slate-200 px-2 py-1 text-xs">Fit</button>
    </div>
    <div data-graph-target="canvas" style="width: 100%; height: 70vh; min-height: 480px;" class="bg-slate-50 rounded"></div>
  </div>
<% end %>

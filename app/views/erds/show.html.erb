<% content_for(:title, "ERD: #{@cluster.name}") %>
<nav class="text-sm text-slate-600 mb-3"><%= link_to "ERDs", erds_path(run: @run.id), class: "underline" %> / <%= @cluster.name %></nav>
<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-semibold"><%= @cluster.name %></h1>
    <p class="text-sm text-slate-600"><%= pluralize(@cluster.sobjects.size, "object") %><% if @cluster.sobjects.size > 50 %> · <span class="text-amber-800">large cluster — may render poorly</span><% end %></p>
  </div>
  <div>
    <%= link_to "Download .mmd", erd_path(@cluster.slug, run: @run.id, format: :mmd), class: "text-sm text-blue-700 underline" %>
  </div>
</div>

<div class="rounded border border-slate-200 bg-white p-4">
  <div data-controller="erd" data-erd-source-value="<%= @mermaid_source %>" class="overflow-x-auto">
    <pre class="mermaid text-sm"><%= @mermaid_source %></pre>
  </div>
</div>

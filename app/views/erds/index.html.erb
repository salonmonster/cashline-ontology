<% content_for(:title, "ERDs") %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold">Per-domain ERDs</h1>
    <p class="text-sm text-slate-600">Clusters auto-computed from the relationship graph. Click into a cluster to view its diagram.</p>
  </div>
  <% if @run && policy(Cluster).edit? %>
    <%= link_to "Edit clusters", edit_clusters_path(run: @run.id), class: "rounded bg-slate-200 px-3 py-2 text-sm" %>
  <% end %>
</div>

<% if @run.nil? %>
  <div class="rounded border border-dashed border-slate-300 p-10 text-center bg-white">
    <p class="text-slate-700">No active run. <%= link_to "Pick one", runs_path, class: "text-blue-700 underline" %>.</p>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @clusters.each do |c| %>
      <div class="rounded border border-slate-200 bg-white p-4">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold"><%= c.name %></h2>
          <span class="inline-block h-3 w-3 rounded" style="background: <%= c.color %>"></span>
        </div>
        <p class="mt-1 text-xs text-slate-600"><%= pluralize(c.sobjects.size, "object") %><% if c.sobjects.size > 50 %> <span class="text-amber-700">(may render poorly)</span><% end %></p>
        <ul class="mt-2 text-xs space-y-0.5 max-h-32 overflow-y-auto">
          <% c.sobjects.order(:api_name).first(20).each do |so| %>
            <li><%= link_to so.api_name, object_path(so.api_name, run: @run.id), class: "font-mono text-slate-700 underline" %></li>
          <% end %>
          <% if c.sobjects.size > 20 %><li class="text-slate-500">… +<%= c.sobjects.size - 20 %> more</li><% end %>
        </ul>
        <div class="mt-3"><%= link_to "Open diagram", erd_path(c.slug, run: @run.id), class: "text-sm text-blue-700 underline" %></div>
      </div>
    <% end %>
  </div>
<% end %>

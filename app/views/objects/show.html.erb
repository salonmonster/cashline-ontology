<% content_for(:title, @sobject.api_name) %>
<% can_see_sensitive = can_view_sensitive_values?(@run, Current.user) %>
<% hide_value_cols = (@run.include_sensitive && !Current.user&.sensitive_data_access?) %>
<nav class="text-sm text-slate-600 mb-3">
  <%= link_to "Runs", runs_path, class: "underline" %> / <%= link_to @run.directory_token, run_path(@run), class: "font-mono underline" %> / <%= link_to "Objects", objects_path(run: @run.id), class: "underline" %> / <span class="font-mono"><%= @sobject.api_name %></span>
</nav>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-semibold"><%= @sobject.api_name %></h1>
    <p class="text-sm text-slate-600"><%= @sobject.label %><% if @sobject.namespace_prefix.present? %> · namespace <code><%= @sobject.namespace_prefix %></code><% end %><% if @sobject.custom %> · custom<% end %></p>
  </div>
  <div class="text-sm text-slate-600">
    <% if @object_profile&.record_count %><span class="rounded bg-slate-100 px-2 py-1">Records: <%= number_with_delimiter(@object_profile.record_count) %></span><% end %>
    <% if @object_profile&.sampled %><span class="ml-1 rounded bg-indigo-100 text-indigo-900 px-2 py-1">Sampled</span><% end %>
  </div>
</div>

<section class="rounded border border-slate-200 bg-white p-4 mb-6">
  <h2 class="text-lg font-semibold mb-3">Fields (<%= @sfields.size %>)</h2>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
        <tr>
          <th class="px-3 py-2">API name</th>
          <th class="px-3 py-2">Type</th>
          <th class="px-3 py-2">Length</th>
          <th class="px-3 py-2">Sensitivity</th>
          <th class="px-3 py-2">Null %</th>
          <th class="px-3 py-2">Distinct</th>
          <% unless hide_value_cols %>
            <th class="px-3 py-2">Top values</th>
            <th class="px-3 py-2">Samples</th>
          <% end %>
          <th class="px-3 py-2">Refs</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @sfields.each do |f| %>
          <% fp = @field_profiles[f.id] %>
          <% may_view_values = f.sensitivity.to_s == "safe" || can_see_sensitive %>
          <tr>
            <td class="px-3 py-2 font-mono text-xs">
              <%= f.api_name %>
              <% if f.calculated %><span class="ml-1 rounded bg-violet-100 text-violet-900 px-1 text-[10px]">calc</span><% end %>
              <% if f.encrypted %><span class="ml-1 rounded bg-rose-100 text-rose-900 px-1 text-[10px]">enc</span><% end %>
            </td>
            <td class="px-3 py-2 text-slate-700"><%= f.data_type %></td>
            <td class="px-3 py-2 text-slate-700"><%= f.length || "—" %></td>
            <td class="px-3 py-2">
              <% if f.sensitivity == "safe" %>
                <span class="text-emerald-700 text-xs"><%= sensitivity_label(f.sensitivity) %></span>
              <% else %>
                <span class="text-amber-800 text-xs"><%= sensitivity_label(f.sensitivity) %></span>
              <% end %>
            </td>
            <td class="px-3 py-2 text-slate-700"><%= fp&.null_rate ? "#{(fp.null_rate * 100).round(1)}%" : "—" %></td>
            <td class="px-3 py-2 text-slate-700">
              <% if fp.nil? %>—
              <% elsif fp.distinct_count_suppressed %><span class="italic text-slate-500" title="Distinct < 5 on sensitive field — suppressed">suppressed</span>
              <% else %><%= fp.distinct_count || "—" %><% end %>
            </td>
            <% unless hide_value_cols %>
              <td class="px-3 py-2">
                <% if fp.nil? || fp.top_values.blank? %>—
                <% elsif may_view_values %>
                  <ul class="text-xs"><% fp.top_values.first(5).each do |tv| %><li><%= tv["v"] %> (<%= tv["c"] %>)</li><% end %></ul>
                <% else %>
                  <%= redacted_cell(f) %>
                <% end %>
              </td>
              <td class="px-3 py-2">
                <% if fp.nil? || fp.sample_values.blank? %>—
                <% elsif may_view_values %>
                  <ul class="text-xs"><% fp.sample_values.first(3).each do |s| %><li><%= s.to_s.truncate(40) %></li><% end %></ul>
                <% else %>
                  <%= redacted_cell(f) %>
                <% end %>
              </td>
            <% end %>
            <td class="px-3 py-2 text-slate-700"><%= f.references_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="rounded border border-slate-200 bg-white p-4 mb-6">
  <h2 class="text-lg font-semibold mb-3">Relationships</h2>
  <div class="grid grid-cols-2 gap-4 text-sm">
    <div>
      <h3 class="font-medium mb-1">Outbound (<%= @outgoing.size %>)</h3>
      <% if @outgoing.empty? %><p class="text-slate-500">None.</p><% else %>
        <ul class="space-y-1">
          <% @outgoing.each do |r| %>
            <li>
              <span class="font-mono text-xs"><%= r.relationship_name || r.source_field&.api_name %></span> →
              <% if r.target_sobject %>
                <%= link_to r.target_sobject.api_name, object_path(r.target_sobject.api_name, run: @run.id), class: "text-blue-700 underline font-mono text-xs" %>
              <% else %>
                <span class="font-mono text-xs text-slate-700"><%= Array(r.reference_to_api_names).join(", ") %></span>
              <% end %>
              <% if r.polymorphic %><span class="ml-1 rounded bg-slate-100 text-slate-700 text-[10px] px-1">poly</span><% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
    <div>
      <h3 class="font-medium mb-1">Inbound (<%= @incoming.size %>)</h3>
      <% if @incoming.empty? %><p class="text-slate-500">None.</p><% else %>
        <ul class="space-y-1">
          <% @incoming.each do |r| %>
            <li>
              <%= link_to r.source_sobject.api_name, object_path(r.source_sobject.api_name, run: @run.id), class: "text-blue-700 underline font-mono text-xs" %>
              <span class="text-slate-500">via</span>
              <span class="font-mono text-xs"><%= r.relationship_name || r.source_field&.api_name %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>
</section>

<% formula_fields = @sfields.select { |f| f.calculated && f.calculated_formula.present? } %>
<% if formula_fields.any? %>
  <section class="rounded border border-slate-200 bg-white p-4">
    <h2 class="text-lg font-semibold mb-3">Formulas / validations</h2>
    <ul class="space-y-3 text-sm">
      <% formula_fields.each do |f| %>
        <li>
          <p class="font-mono text-xs text-slate-700"><%= f.api_name %></p>
          <pre class="mt-1 rounded bg-slate-50 p-2 text-xs overflow-x-auto"><%= f.calculated_formula %></pre>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# Fields table for a single sobject. Reused by:
    - objects/show.html.erb (the standalone page)
    - objects/fields.html.erb (the inline Turbo Frame inside objects/index)

    Locals:
      sobject         — Sobject
      sfields         — preloaded Sfield collection (ordered)
      field_profiles  — { sfield_id => FieldProfile }
      run             — ExtractionRun
      object_profile  — ObjectProfile (or nil)
      hide_value_cols — bool, hide Top/Samples for sensitive runs lacking access
      can_see_sensitive — bool, may view sensitive values
      compact         — bool, render in inline-expand mode (omits some chrome) %>

<% compact = local_assigns.fetch(:compact, false) %>
<% type_counts = sfields.group_by(&:data_type).transform_values(&:size).sort_by { |_t, c| -c } %>
<% chip_active = "rounded bg-slate-900 text-white px-2 py-1 text-[11px] font-medium" %>
<% chip_inactive = "rounded border border-slate-300 bg-white text-slate-700 hover:border-slate-500 px-2 py-1 text-[11px]" %>

<div data-controller="type-filter"
     data-type-filter-active-class-value="<%= chip_active %>"
     data-type-filter-inactive-class-value="<%= chip_inactive %>">
  <% if type_counts.size > 1 %>
    <div class="mb-2 flex items-center gap-1.5 flex-wrap">
      <span class="text-[11px] uppercase tracking-wide text-slate-500 font-medium mr-1">Type:</span>
      <button type="button"
              data-type-filter-target="chip"
              data-action="click->type-filter#filter"
              data-type-value="all"
              class="<%= chip_active %>">All (<%= sfields.size %>)</button>
      <% type_counts.each do |t, c| %>
        <button type="button"
                data-type-filter-target="chip"
                data-action="click->type-filter#filter"
                data-type-value="<%= t %>"
                class="<%= chip_inactive %>"><%= t %> (<%= c %>)</button>
      <% end %>
    </div>
  <% end %>

  <div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-slate-200 text-sm" data-controller="sortable-table">
    <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
      <tr>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="text">API name<span class="sort-indicator"></span></th>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="text">Type<span class="sort-indicator"></span></th>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="number">Length<span class="sort-indicator"></span></th>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="text">Sensitivity<span class="sort-indicator"></span></th>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="number">Null %<span class="sort-indicator"></span></th>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="number">Distinct<span class="sort-indicator"></span></th>
        <% unless hide_value_cols %>
          <th class="px-3 py-2">Top values</th>
          <th class="px-3 py-2">Samples</th>
        <% end %>
        <th class="px-3 py-2 cursor-pointer select-none hover:bg-slate-200" data-action="click->sortable-table#sort" data-sort-type="number">Refs<span class="sort-indicator"></span></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100" data-sortable-table-target="body">
      <% sfields.each do |f| %>
        <% fp = field_profiles[f.id] %>
        <% may_view_values = f.sensitivity.to_s == "safe" || can_see_sensitive %>
        <% field_frame_id = dom_id(f, :detail) %>
        <% col_count = hide_value_cols ? 7 : 9 %>
        <tr data-field-name="<%= f.api_name %>"
            data-field-type="<%= f.data_type %>"
            data-controller="expandable"
            data-expandable-frame-id-value="<%= field_frame_id %>"
            data-expandable-frame-url-value="<%= field_object_path(sobject.api_name, field_name: f.api_name, run: run.id) %>">
          <td class="px-3 py-2 font-mono text-xs" data-sort-value="<%= f.api_name %>">
            <button type="button"
                    data-action="click->expandable#toggle"
                    class="mr-1 inline-block w-3 text-slate-400 hover:text-slate-900"
                    aria-label="Expand field detail"
                    title="Show extended view">
              <span data-expandable-target="chevron">▸</span>
            </button>
            <%= f.api_name %>
            <% if f.calculated %><span class="ml-1 rounded bg-violet-100 text-violet-900 px-1 text-[10px]">calc</span><% end %>
            <% if f.encrypted %><span class="ml-1 rounded bg-rose-100 text-rose-900 px-1 text-[10px]">enc</span><% end %>
          </td>
          <td class="px-3 py-2 text-slate-700"><%= f.data_type %></td>
          <td class="px-3 py-2 text-slate-700" data-sort-value="<%= f.length %>"><%= f.length || "—" %></td>
          <td class="px-3 py-2" data-sort-value="<%= f.sensitivity %>">
            <% if f.sensitivity == "safe" %>
              <span class="text-emerald-700 text-xs"><%= sensitivity_label(f.sensitivity) %></span>
            <% else %>
              <span class="text-amber-800 text-xs"><%= sensitivity_label(f.sensitivity) %></span>
            <% end %>
          </td>
          <td class="px-3 py-2 text-slate-700" data-sort-value="<%= fp&.null_rate %>"><%= fp&.null_rate ? "#{(fp.null_rate * 100).round(1)}%" : "—" %></td>
          <td class="px-3 py-2 text-slate-700" data-sort-value="<%= fp&.distinct_count_suppressed ? nil : fp&.distinct_count %>">
            <% if fp.nil? %>—
            <% elsif fp.distinct_count_suppressed %><span class="italic text-slate-500" title="Distinct < 5 on sensitive field — suppressed">suppressed</span>
            <% else %><%= fp.distinct_count || "—" %><% end %>
          </td>
          <% unless hide_value_cols %>
            <td class="px-3 py-2">
              <% if fp.nil? || fp.top_values.blank? %>—
              <% elsif may_view_values %>
                <ul class="text-xs"><% fp.top_values.first(5).each do |tv| %><li><%= tv["value"] || tv["v"] %> (<%= tv["count"] || tv["c"] %>)</li><% end %></ul>
              <% else %>
                <%= redacted_cell(f) %>
              <% end %>
            </td>
            <td class="px-3 py-2">
              <% if fp.nil? || fp.sample_values.blank? %>—
              <% elsif may_view_values %>
                <ul class="text-xs"><% fp.sample_values.first(3).each do |s| %><li><%= s.to_s.truncate(40) %></li><% end %></ul>
              <% else %>
                <%= redacted_cell(f) %>
              <% end %>
            </td>
          <% end %>
          <td class="px-3 py-2 text-slate-700"><%= f.references_count %></td>
        </tr>
        <tr id="<%= field_frame_id %>-row" class="hidden" data-detail-for="<%= f.api_name %>" data-field-type="<%= f.data_type %>">
          <td colspan="<%= col_count %>" class="p-0 border-0">
            <%= turbo_frame_tag field_frame_id do %>
              <div class="bg-slate-50 px-4 py-2 text-xs text-slate-500">Loading field detail…</div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
